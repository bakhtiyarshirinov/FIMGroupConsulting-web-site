# PostgreSQL connection string (from Neon, Supabase, Railway, or any Postgres provider)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Admin panel credentials — change before deploying
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Long random string for JWT signing (min 32 chars)
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# Your production domain (used for metadata and OG tags)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
